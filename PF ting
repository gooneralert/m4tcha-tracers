local function getIgnoreList()
    local ignore = {}
    if player.Character then
        local charParts = Raycaster:GatherParts(player.Character)
        for i = 1, #charParts do
            table.insert(ignore, charParts[i])
        end
    end
    return ignore
end

-- Walk up parent hierarchy to detect if the part is part of the player's arms/hands
local function isArmDescendant(instance)
    local current = instance
    while current and current ~= game do
        local nameLower = current.Name:lower()
        if string.find(nameLower, "arm") 
           or string.find(nameLower, "sleeve") 
           or string.find(nameLower, "skintone") 
           or string.find(nameLower, "hand") then
            return true
        end
        current = current.Parent
    end
    return false
end

local function findPFMuzzlePart()
    local cam = getActiveCamera()
    if not cam then return nil end
    
    local descendants = cam:GetDescendants()
    for i = 1, #descendants do
        local child = descendants[i]
        if child and BASE_PART_CLASSES[child.ClassName] then
            -- Verify this part is not an arm or hand mesh
            if not isArmDescendant(child) then
                -- Find the SpecialMesh child directly, ignoring sibling dynamic sound additions
                local mesh = child:FindFirstChildOfClass("SpecialMesh")
                if mesh then
                    return child
                end
            end
        end
    end
    return nil
end

local resolvedMuzzlePart = nil
local lastMuzzleScan = 0

-- Unconditional active viewmodel scanning running on a strict 0.5s timer
local function getOriginPart(character)
    local now = tick()
    
    if not resolvedMuzzlePart or resolvedMuzzlePart.Parent == nil or (now - lastMuzzleScan > 0.5) then
        lastMuzzleScan = now
        
        local found = findPFMuzzlePart()
        
        if found then
            resolvedMuzzlePart = found
        else
            local headPart = character and character:FindFirstChild("Head")
            resolvedMuzzlePart = headPart
        end
    end
    
    return resolvedMuzzlePart
end

-- Safe path traversal to locate active weapon ammo labels in PlayerGui
local function getMagCountLabel()
    if not player then return nil end
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    
    local hudScreenGui = playerGui:FindFirstChild("HudScreenGui")
    local main = hudScreenGui and hudScreenGui:FindFirstChild("Main")
    local displayStatus = main and main:FindFirstChild("DisplayStatus")
    local textMagCount = displayStatus and displayStatus:FindFirstChild("TextMagCount")
    
    return textMagCount
end

-- Trigger a safe raycast simulation and generate active lines
local function triggerTracer()
    local character = player.Character
    local originPart = getOriginPart(character)
    
    if originPart then
        -- Safely extract position to prevent destroyed instance crashes
        local successPos, posVal = pcall(function() return originPart.Position end)
        if not successPos or not posVal then
            return -- Abort gracefully if part is invalid/destroyed on this frame
        end
        
        local origin = posVal
        local maxRange = 1000
        
        local cf
        local successCF, cfVal = pcall(function() return originPart.CFrame end)
        if successCF and cfVal then
            cf = cfVal
        else
            cf = CFrame.new(origin)
        end
        
        -- Resolve shooting direction directly from viewmodel's resolved forward vector (LookVector)
        local direction = Vector3.new(0, 0, -maxRange)
        if cf then
            local successMuzzleLook, muzzleLookVal = pcall(function() return cf.LookVector end)
            if successMuzzleLook and muzzleLookVal then
                direction = muzzleLookVal * maxRange
            end
        end
        
        local ignoreList = getIgnoreList()
        local result = Raycaster:Raycast(origin, direction, ignoreList)
        
        local targetPosition
        if result then
            targetPosition = result.Position
        else
            targetPosition = origin + direction
        end
        
        registerTracer(origin, targetPosition)
    end
end

