-- 5. DRAWING MANAGER
-- =====================================================================
local activeTracers = {}
local drawings = {}
local lastFrameDrawCount = 0 -- Tracks active drawings from the previous frame to avoid blanket resets

local function lerp(a, b, t) return a + (b - a) * t end
local function lerpColor(c1, c2, t)
    return Color3.new(lerp(c1.R, c2.R, t), lerp(c1.G, c2.G, t), lerp(c1.B, c2.B, t))
end

local function sampleColors(t)
    local cols = cfg.colors
    local n = #cols
    if n == 1 then return cols[1] end
    if t <= 0 then return cols[1] end
    if t >= 1 then return cols[n] end
    local scaled = t * (n - 1)
    local idx = math.floor(scaled)
    return lerpColor(cols[idx + 1], cols[idx + 2], scaled - idx)
end

local function hsvToColor(h, s, v)
    h = h % 1
    local i = math.floor(h * 6)
    local f = h * 6 - i
    local p = v * (1 - s)
    local q = v * (1 - f * s)
    local t = v * (1 - (1 - f) * s)
    i = i % 6
    if i == 0 then return Color3.new(v, t, p) end
    if i == 1 then return Color3.new(q, v, p) end
    if i == 2 then return Color3.new(p, v, t) end
    if i == 3 then return Color3.new(p, q, v) end
    if i == 4 then return Color3.new(t, p, v) end
    return Color3.new(v, p, q)
end

local function gOC(idx)
    if not drawings[idx] then
        local ok, d = pcall(Drawing.new, "Line")
        if ok and d then
            drawings[idx] = d
        else
            return nil
        end
    end
    return drawings[idx]
end

-- PRE-ALLOCATE OBJECT POOL
-- This prevents the executor from suffering garbage collection spikes and thread-blocking allocations mid-combat
local PRE_ALLOCATE_COUNT = 300
task.spawn(function()
    for i = 1, PRE_ALLOCATE_COUNT do
        gOC(i)
        if i % 15 == 0 then
            task.wait() -- Spread initialization work smoothly over several frames
        end
    end
end)

local function registerTracer(startPos, endPos)
    table.insert(activeTracers, {
        start = startPos,
        target = endPos,
        t = os.clock()
    })
end

local function renderTracers()
    local now = os.clock()
    local drawIdx = 0

    if not cfg.enabled then 
        -- Clean up previously active drawings immediately if disabled
        for idx = 1, lastFrameDrawCount do
            local d = drawings[idx]
            if d then d.Visible = false end
        end
        lastFrameDrawCount = 0
        return 
    end

    local aliveTracers = {}
    for tIdx = 1, #activeTracers do
        local tracer = activeTracers[tIdx]
        local age = now - tracer.t
        local alpha = math.max(0, 1 - age / cfg.fadeTime)

        if alpha > 0.01 then
            table.insert(aliveTracers, tracer)

            -- Calculate vector properties first so segments can scale dynamically
            local dir, right, trueUp, lengthFactor, freqRatio = nil, nil, nil, 1.0, 1.0
            local displacementVec = tracer.target - tracer.start
            local magnitude = displacementVec.Magnitude
            if magnitude > 0 then
                dir = displacementVec / magnitude
                local up = math.abs(dir.Y) > 0.99 and Vector3.new(1, 0, 0) or Vector3.new(0, 1, 0)
                right = dir:Cross(up).Unit
                trueUp = right:Cross(dir).Unit
                
                -- Amplitude and frequency modifiers dynamically mapped to physical length
                lengthFactor = math.clamp(magnitude / 150, 0.05, 0.75) -- Max displacement capped at 0.75 to prevent wild shaking on long shots
                freqRatio = math.clamp(magnitude / 250, 0.15, 1.6)     -- Cap wavelength frequency scaling to prevent erratic clustering
            end

            -- Determine segment counts dynamically
            local numSegments = cfg.segments or 5
            if cfg.trailType == "solid" then
                numSegments = 1
            elseif cfg.trailType == "Rope kinda?" then
                -- Scale segments proportionally to the normalized frequency ratio to prevent rendering jagged aliasing
                numSegments = math.max(numSegments, math.floor(15 * freqRatio))
                numSegments = math.clamp(numSegments, 15, 45) -- Cap to 45 segments for performance
            end

            local function getElectricOffset(t)
                if not right or t <= 0 or t >= 1 then return Vector3.zero end
                local envelope = math.sin(t * math.pi)
                
                -- Optimization: Stretch wave progressively near the target end (t -> 1) to counteract 3D perspective foreshortening
                local stretch = (1 - t * t * 0.65)
                local angleX = t * (5 * freqRatio) * stretch - now * 10 + tIdx
                local angleY = t * (11 * freqRatio) * stretch + now * 12 - tIdx
                
                -- Clean overlapping sine waves with adjusted base frequencies to prevent chaotic clustering
                local waveX = math.sin(angleX) * 1.5 + math.cos(angleX * 2.2) * 0.4
                local waveY = math.cos(angleY) * 1.5 + math.sin(angleY * 2.2) * 0.4
                    
                local scale = (1.5 + cfg.thickness * 0.5) * envelope * lengthFactor
                return right * (waveX * scale) + trueUp * (waveY * scale)
            end

            for sIdx = 1, numSegments do
                local t1 = (sIdx - 1) / numSegments
                local t2 = sIdx / numSegments

                local p1 = tracer.start:Lerp(tracer.target, t1)
                local p2 = tracer.start:Lerp(tracer.target, t2)

                -- Apply displacement for electricity noise
                if cfg.trailType == "Rope kinda?" then
                    p1 = p1 + getElectricOffset(t1)
                    p2 = p2 + getElectricOffset(t2)
                end

                local sp1, onScreen1 = MatchaWorldToScreen(p1)
                local sp2, onScreen2 = MatchaWorldToScreen(p2)

                if onScreen1 and onScreen2 then
                    local prevSP = Vector2.new(sp1.X, sp1.Y)
                    local curSP = Vector2.new(sp2.X, sp2.Y)

                    local tt = cfg.trailType
                    local col = sampleColors(t1)
                    local thickness = cfg.thickness
                    local isNeon = tt == "neon"
                    local neonA

                    if tt == "gradient" then
                        col = sampleColors(t1)
                    elseif tt == "pulse" then
                        thickness = cfg.thickness * (1 + 0.4 * math.sin(now * 12 + tIdx + sIdx * 0.2))
                    elseif tt == "rainbow" then
                        col = hsvToColor((now * 0.5 + t1 * 0.5) % 1, 0.85, 1)
                    elseif tt == "flicker" then
                        local aT = math.sin(now * 15 + t1 * math.pi) * 0.5 + 0.5
                        col = sampleColors(aT)
                    elseif tt == "neon" then
                        col = sampleColors(t1)
                        neonA = alpha * (0.85 + 0.15 * math.sin(now * 8 + tIdx * 0.5))
                    end

                    if tt == "Rope kinda?" then
                        -- Progressively fade thickness and transparency along the length of the tracer
                        local fadeFactor = (1 - t1) * 0.9 + 0.1
                        local elecAlpha = alpha * fadeFactor * (0.8 + 0.2 * math.sin(now * 25 + tIdx * 10 + sIdx)) -- Organic flickering
                        local elecThickness = cfg.thickness * fadeFactor

                        -- 5-Layer Amplified Glow Profile
                        local layers = {
                            { elecThickness * 14,  elecAlpha * 0.04 }, -- Broad, soft outer halo
                            { elecThickness * 7,   elecAlpha * 0.12 }, -- Medium bloom ring
                            { elecThickness * 3.5, elecAlpha * 0.32 }, -- Tight core glow
                            { elecThickness * 1.6, elecAlpha * 0.7  }, -- Strong inner core
                            { elecThickness * 0.6, elecAlpha        }, -- Sharp bright center core
                        }
                        for _, layer in ipairs(layers) do
                            drawIdx = drawIdx + 1
                            local d = gOC(drawIdx)
                            if d then
                                d.From = prevSP
                                d.To = curSP
                                d.Color = col
                                d.Thickness = layer[1]
                                d.Transparency = layer[2]
                                d.ZIndex = 5
                                d.Visible = true
                            end
                        end
                    elseif isNeon then
                        local neonLayers = {
                            { cfg.thickness * 9,   neonA * 0.08 },
                            { cfg.thickness * 4.5, neonA * 0.2  },
                            { cfg.thickness * 1.8, neonA * 0.7  },
                            { cfg.thickness * 0.7, neonA        },
                        }
                        for _, layer in ipairs(neonLayers) do
                            drawIdx = drawIdx + 1
                            local d = gOC(drawIdx)
                            if d then
                                d.From = prevSP
                                d.To = curSP
                                d.Color = col
                                d.Thickness = layer[1]
                                d.Transparency = layer[2]
                                d.ZIndex = 5
                                d.Visible = true
                            end
                        end
                    else
                        drawIdx = drawIdx + 1
                        local d = gOC(drawIdx)
                        if d then
                            d.From = prevSP
                            d.To = curSP
                            d.Color = col
                            d.Thickness = thickness
                            d.Transparency = alpha
                            d.ZIndex = 5
                            d.Visible = true
                        end
                    end
                end
            end
        end
    end
    
    -- Smart Visibility Cleanup: Only toggle elements transitioning from active to inactive
    for idx = drawIdx + 1, lastFrameDrawCount do
        local d = drawings[idx]
        if d then
            d.Visible = false
        end
    end
    lastFrameDrawCount = drawIdx

    activeTracers = aliveTracers
end

