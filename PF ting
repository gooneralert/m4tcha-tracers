                                end
                            end
                        end
                    end
                end)
                
                -- Safely clear out inactive dog tag trackers
                for key, tracker in pairs(tagTrackers) do
                    if not aliveKeys[key] then
                        pcall(function() tracker:Destroy() end)
                        tagTrackers[key] = nil
                    end
                end
                
                task.wait(0.5)
            end
        end)
    else
        -- Unload active tag drawings immediately
        for key, tracker in pairs(tagTrackers) do
            pcall(function() tracker:Destroy() end)
            tagTrackers[key] = nil
        end
    end
end)

