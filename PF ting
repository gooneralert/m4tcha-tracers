-- 7. DYNAMIC SHOOTING LOOP
-- =====================================================================
local function handleTracerAndInputs()
    camera = getActiveCamera()

    -- Keep active tracers rendering
    renderTracers()

    if not isrbxactive() then 
        return 
    end
    
    -- Bullet tracking loop: Triggers exactly when TextMagCount drops by 1
    local magLabel = getMagCountLabel()
    if magLabel then
        local rawText = magLabel.Text
        if rawText then
            local cleanText = rawText:gsub("%s+", "")
            local currentAmmo = tonumber(cleanText)
            
            if currentAmmo then
                -- Verify if ammo value has dropped relative to the last captured frame
                if lastAmmoValue and currentAmmo < lastAmmoValue then
                    triggerTracer()
                end
                lastAmmoValue = currentAmmo
            else
                lastAmmoValue = nil
            end
        end
    else
        lastAmmoValue = nil
    end
end

local connection = RunService.RenderStepped:Connect(handleTracerAndInputs)

-- =====================================================================
-- REGISTRATION OF CLEANUP HOOK
-- =====================================================================
_G.MatchaTracerCleanup = function()
    if connection then connection:Disconnect() end
    if backgroundScanner then pcall(task.cancel, backgroundScanner) end
    
    if Cache.activeThread then
        pcall(task.cancel, Cache.activeThread)
    end
    
    gunEspActive = false
    tagEspActive = false
    
    if trackers then
        for key, tracker in next, trackers do
            pcall(function() tracker:Destroy() end)
        end
        table.clear(trackers)
    end
    
    if tagTrackers then
        for key, tracker in pairs(tagTrackers) do
            pcall(function() tracker:Destroy() end)
        end
        table.clear(tagTrackers)
    end
    
    if _G.MatchaTracerWindow then
        pcall(function() _G.MatchaTracerWindow:Destroy() end)
        _G.MatchaTracerWindow = nil
    end

    for i = 1, #drawings do
        local d = drawings[i]
        if d then 
            pcall(function() d:Remove() end)
        end
    end
    table.clear(drawings)
    table.clear(activeTracers)
    lastFrameDrawCount = 0
end
