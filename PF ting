-- Weapon name caching to completely eliminate RenderStepped polling lag [11]
local gunCache = {}
local lastCacheTime = {}

local function getGun(playerFolder)
    local now = os.clock()
    local folderName = playerFolder.Name
    local lastTime = lastCacheTime[folderName]
    
    if not lastTime or (now - lastTime > 0.5) then
        lastCacheTime[folderName] = now
        local resolvedName = "Unknown"
        
        for _, child in next, playerFolder:GetChildren() do
            if child.ClassName == "Model" then
                local gunName = child.Name
                gunName = gunName:gsub("Main", ""):gsub("^%s+", ""):gsub("%s+$", "")
                if gunName ~= "" then
                    resolvedName = gunName
                    break
                end
            end
        end
        gunCache[folderName] = resolvedName
    end
    
    return gunCache[folderName] or "Unknown"
end

-- Base ESP Loader check
local function ensureEspUtilityLoaded()
    if not _G.ESP_Utility then
        local URL = "https://raw.githubusercontent.com/artxficial/matchastuff/main/esp_utility.lua"
        local success, src = pcall(game.HttpGet, game, URL)
        if success and src then
            src = src:gsub("game%.Players%.LocalPlayer", 'game:GetService("Players").LocalPlayer')
            src = src:gsub("game%.Players", 'game:GetService("Players")')
            src = src:gsub('self:AddText%("Distance".-end%)', '')
            
            local fn, err = loadstring(src)
            if fn then
                fn()
            end
        end
    end
    
    local ESP = _G.ESP_Utility or ESP_Utility
    if not ESP then return nil end
    
    -- Patch the update cycle and metatables with a static patch guard to prevent recursive stack leaks [11]
    if not ESP._patched then
        ESP._patched = true
        
        pcall(function()
            ESP._GetDistance = function(self)
                return 0
            end

            ESP._IsAlive = function(self)
                if not self.Object then return false end
                return true
            end

            -- Overwrite internal update methods to add a metatable guard
            -- This prevents 'attempt to call missing method _DetermineVisibility' if elements are destroyed mid-frame
            local originalUpdate = ESP._Update
            ESP._Update = function(self)
                if not getmetatable(self) then return end
                if not self._IsAlive or not self._DetermineVisibility then return end
                
                local success, err = pcall(originalUpdate, self)
                if not success then
                    pcall(function() self:Destroy() end)
                end
            end

            -- Custom Leak-Proof Destroy: Re-implemented to safely purge drawings even if Object is nil
            local originalDestroy = ESP.Destroy
            ESP.Destroy = function(self)
                -- 1. Safely remove from the internal tracking table to stop update threads
                pcall(function()
                    if self.Object and self.Object.Address and ESP.TrackersToUpdate then
                        ESP.TrackersToUpdate[self.Object.Address] = nil
                    end
                end)
                
                -- 2. Forcefully clean up drawings in memory to prevent Matcha crashes/leaks
                pcall(function()
                    if self.Drawings then
                        for _, drawObj in pairs(self.Drawings) do
                            if type(drawObj) == "table" and drawObj.Drawing then
                                pcall(function() drawObj.Drawing:Remove() end)
                            elseif type(drawObj) == "table" then
                                pcall(function() drawObj:Remove() end)
                            else
                                pcall(function() drawObj:Remove() end)
                            end
                        end
                    end
                end)
                
                pcall(originalDestroy, self)
            end
        end)
    end
    return ESP
end

